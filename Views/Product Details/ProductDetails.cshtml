@{
    ViewData["Title"] = "Product Details & Ledger";
}

<div class="container-fluid my-4">
    <!-- Breadcrumb & Back -->
    <div class="d-flex justify-content-between align-items-center mb-4">
        <nav aria-label="breadcrumb">
            <ol class="breadcrumb mb-0">
                <li class="breadcrumb-item"><a asp-controller="Home" asp-action="Index" class="text-decoration-none text-muted">Home</a></li>
                <li class="breadcrumb-item active" aria-current="page">Product Details Ledger</li>
            </ol>
        </nav>
        <a asp-controller="Home" asp-action="Index" class="btn-outline-premium btn-sm">
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" class="me-1"><line x1="19" y1="12" x2="5" y2="12"></line><polyline points="12 19 5 12 12 5"></polyline></svg>
            Back to Home
        </a>
    </div>

    <!-- Header Section -->
    <div class="mb-4">
        <h1 class="fw-bold">Meesho Product Details & Financial Ledger</h1>
        <p class="text-muted">Track stock, shipment timelines, investments, credits, profits, and payment clearance status for your listings.</p>
    </div>

    <!-- Interactive Ledger Card -->
    <div class="glass-card p-4">
        <div class="d-flex justify-content-between align-items-center mb-3 flex-wrap gap-2">
            <h4 class="fw-semibold mb-0">Product Catalog & Ledger Logs</h4>
            <button class="btn-premium btn-sm" data-bs-toggle="modal" data-bs-target="#addProductModal">
                <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" class="me-1"><line x1="12" y1="5" x2="12" y2="19"></line><line x1="5" y1="12" x2="19" y2="12"></line></svg>
                Add New Entry
            </button>
        </div>

        <div class="table-responsive">
            <table class="table table-hover align-middle" id="ledgerTable">
                <thead>
                    <tr class="border-bottom border-secondary text-uppercase fs-7 text-muted">
                        <th scope="col" style="width: 60px;">S.No</th>
                        <th scope="col">SKU ID</th>
                        <th scope="col" style="width: 100px;">Photo</th>
                        <th scope="col">Stock</th>
                        <th scope="col">Upload Date</th>
                        <th scope="col">Courier</th>
                        <th scope="col">Pickup Date</th>
                        <th scope="col">Invested (₹)</th>
                        <th scope="col">Credited (₹)</th>
                        <th scope="col">Profit (₹)</th>
                        <th scope="col" style="width: 160px;">Payment Status</th>
                        <th scope="col" class="conditional-col d-none">Payment Date</th>
                        <th scope="col" class="conditional-col d-none">Arrived</th>
                        <th scope="col" style="width: 80px;">Action</th>
                    </tr>
                </thead>
                <tbody id="ledgerTableBody">
                    <!-- Loaded dynamically via AJAX -->
                    <tr id="loadingRow">
                        <td colspan="14" class="text-center text-muted py-5">
                            <div class="spinner-border spinner-border-sm text-pink me-2" role="status"></div>
                            Loading product ledger details...
                        </td>
                    </tr>
                </tbody>
            </table>
        </div>
    </div>
</div>

<!-- Add Product Modal -->
<div class="modal fade" id="addProductModal" tabindex="-1" aria-labelledby="addProductModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content glass-modal">
            <div class="modal-header">
                <h5 class="modal-title fw-bold" id="addProductModalLabel">Add New Product</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <form id="addProductForm" enctype="multipart/form-data">
                <div class="modal-body">
                    <div class="mb-3">
                        <label for="productPhoto" class="form-label fs-7 text-uppercase">Product Image</label>
                        <input type="file" class="form-control" id="productPhoto" name="productPhoto" accept="image/*" />
                        <div id="photoPreviewContainer" class="d-none mt-2 p-1 border border-secondary rounded position-relative" style="width: 100px; height: 100px;">
                            <img id="photoPreview" class="w-100 h-100 object-fit-cover rounded" alt="Selected product preview" />
                            <button type="button" class="btn btn-sm btn-danger position-absolute top-0 end-0 p-1 m-1 line-height-1 rounded-circle" style="font-size: 8px; width: 18px; height: 18px; display: flex; align-items: center; justify-content: center;" onclick="clearPhotoSelection()">×</button>
                        </div>
                    </div>
                    <div class="mb-3">
                        <label for="skuId" class="form-label fs-7 text-uppercase">SKU ID</label>
                        <input type="text" class="form-control" id="skuId" name="skuId" placeholder="e.g. MEESHO-SAREE-01" required />
                    </div>
                    <div class="mb-3">
                        <label for="stock" class="form-label fs-7 text-uppercase">Stock</label>
                        <input type="number" class="form-control" id="stock" name="stock" value="1" min="1" required />
                    </div>
                    <div class="mb-3">
                        <label for="dateOfUpload" class="form-label fs-7 text-uppercase">Date of Upload</label>
                        <input type="date" class="form-control" id="dateOfUpload" name="dateOfUpload" required />
                    </div>
                    <div class="mb-3">
                        <label for="investedAmount" class="form-label fs-7 text-uppercase">Invested Amount (₹)</label>
                        <input type="number" class="form-control" id="investedAmount" name="investedAmount" min="0" step="0.01" required />
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">Cancel</button>
                    <button type="submit" class="btn btn-premium">Save Product</button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
<script>
    document.addEventListener("DOMContentLoaded", function () {
        // Set default date of upload to today
        document.getElementById("dateOfUpload").value = new Date().toISOString().split('T')[0];
        
        loadProducts();

        // Handle Form Submit
        document.getElementById("addProductForm").addEventListener("submit", function (e) {
            e.preventDefault();
            saveProduct();
        });

        // Photo preview listener
        const productPhotoInput = document.getElementById("productPhoto");
        const photoPreviewContainer = document.getElementById("photoPreviewContainer");
        const photoPreview = document.getElementById("photoPreview");

        productPhotoInput.addEventListener("change", function () {
            const file = this.files[0];
            if (file) {
                const reader = new FileReader();
                reader.onload = function (e) {
                    photoPreview.src = e.target.result;
                    photoPreviewContainer.classList.remove("d-none");
                };
                reader.readAsDataURL(file);
            } else {
                clearPhotoSelection();
            }
        });
    });

    function loadProducts() {
        fetch('/ProductDetails/getProductsList')
            .then(res => res.json())
            .then(res => {
                if (res.statusCode === 200) {
                    renderProducts(res.data);
                } else {
                    alert("Failed to load products: " + res.message);
                }
            })
            .catch(err => {
                console.error("Error loading products:", err);
                document.getElementById("ledgerTableBody").innerHTML = 
                    `<tr><td colspan="14" class="text-center text-danger py-4">Error loading ledger data from server.</td></tr>`;
            });
    }

    function renderProducts(products) {
        const tbody = document.getElementById("ledgerTableBody");
        tbody.innerHTML = "";

        if (products.length === 0) {
            tbody.innerHTML = `<tr><td colspan="14" class="text-center py-5 text-muted fw-semibold">No products</td></tr>`;
            toggleConditionalColumns();
            return;
        }

        products.forEach((p, index) => {
            const tr = document.createElement("tr");
            tr.id = "row_" + p.productId;
            tr.className = "border-bottom border-secondary";

            const profit = p.creditedAmount - p.investedAmount;
            const profitClass = profit >= 0 ? "text-success" : "text-danger";

            tr.innerHTML = `
                <td class="s-no fw-semibold">${index + 1}</td>
                <td>
                    <input type="text" class="form-control form-control-sm bg-transparent border-0 fw-medium w-100 sku-id-input" value="${p.skuId}" onblur="saveRow(${p.productId})" />
                </td>
                <td>
                    <div class="position-relative overflow-hidden rounded border border-secondary" style="width: 60px; height: 60px;">
                        <img src="${p.productPhoto || '/images/product_saree.png'}" alt="Product image" class="w-100 h-100 object-fit-cover hover-zoom" />
                    </div>
                </td>
                <td>
                    <input type="number" class="form-control form-control-sm bg-transparent border-0 w-75 stock-input" value="${p.stock}" min="1" onblur="saveRow(${p.productId})" />
                </td>
                <td>
                    <input type="date" class="form-control form-control-sm bg-transparent border-0 date-of-upload-input" value="${p.dateOfUpload || ''}" onblur="saveRow(${p.productId})" />
                </td>
                <td>
                    <input type="text" class="form-control form-control-sm bg-transparent border-0 courier-name-input" value="${p.courierName || ''}" placeholder="Courier" onblur="saveRow(${p.productId})" />
                </td>
                <td>
                    <input type="date" class="form-control form-control-sm bg-transparent border-0 date-of-pickup-input" value="${p.dateOfPickup || ''}" onblur="saveRow(${p.productId})" />
                </td>
                <td>
                    <input type="number" class="form-control form-control-sm bg-transparent border-0 invested-amt-input" value="${p.investedAmount}" step="0.01" onblur="saveRow(${p.productId})" />
                </td>
                <td>
                    <input type="number" class="form-control form-control-sm bg-transparent border-0 credited-amt-input" value="${p.creditedAmount}" step="0.01" onblur="saveRow(${p.productId})" />
                </td>
                <td class="profit-amt ${profitClass} fw-bold">₹${profit.toLocaleString('en-IN')}</td>
                <td>
                    <select class="form-select form-select-sm payment-status-select" onchange="onStatusChange(${p.productId})">
                        <option value="Unscheduled" ${p.paymentStatus === 'Unscheduled' ? 'selected' : ''}>Unscheduled</option>
                        <option value="Pending" ${p.paymentStatus === 'Pending' ? 'selected' : ''}>Pending</option>
                    </select>
                </td>
                <td class="conditional-col d-none">
                    <input type="date" class="form-control form-control-sm date-of-payment-input" value="${p.dateOfPayment || ''}" onblur="saveRow(${p.productId})" />
                </td>
                <td class="conditional-col d-none">
                    <select class="form-select form-select-sm arrived-select" onchange="saveRow(${p.productId})">
                        <option value="No" ${p.arrived === 'No' ? 'selected' : ''}>No</option>
                        <option value="Yes" ${p.arrived === 'Yes' ? 'selected' : ''}>Yes</option>
                    </select>
                </td>
                <td>
                    <button class="btn btn-sm btn-outline-danger border-0" onclick="deleteProduct(${p.productId})">
                        🗑️
                    </button>
                </td>
            `;

            tbody.appendChild(tr);
        });

        toggleConditionalColumns();
    }

    function toggleConditionalColumns() {
        const selectElements = document.querySelectorAll(".payment-status-select");
        let hasPending = false;

        selectElements.forEach(select => {
            if (select.value === "Pending") {
                hasPending = true;
            }
        });

        const conditionalCols = document.querySelectorAll(".conditional-col");
        conditionalCols.forEach(col => {
            if (hasPending) {
                col.classList.remove("d-none");
            } else {
                col.classList.add("d-none");
            }
        });
    }

    function onStatusChange(rowId) {
        const row = document.getElementById("row_" + rowId);
        if (row) {
            const statusSelect = row.querySelector(".payment-status-select");
            const dateInput = row.querySelector(".date-of-payment-input");
            const arrivedSelect = row.querySelector(".arrived-select");
            
            if (statusSelect.value !== "Pending") {
                if (dateInput) dateInput.value = "";
                if (arrivedSelect) arrivedSelect.value = "No";
            }
        }
        toggleConditionalColumns();
        saveRow(rowId);
    }

    function saveRow(rowId) {
        const row = document.getElementById("row_" + rowId);
        if (!row) return;

        const skuId = row.querySelector(".sku-id-input").value;
        const stock = parseInt(row.querySelector(".stock-input").value) || 1;
        const dateOfUpload = row.querySelector(".date-of-upload-input").value;
        const courierName = row.querySelector(".courier-name-input").value;
        const dateOfPickup = row.querySelector(".date-of-pickup-input").value;
        const investedAmount = parseFloat(row.querySelector(".invested-amt-input").value) || 0;
        const creditedAmount = parseFloat(row.querySelector(".credited-amt-input").value) || 0;
        const paymentStatus = row.querySelector(".payment-status-select").value;
        const dateOfPayment = row.querySelector(".date-of-payment-input")?.value || "";
        const arrived = row.querySelector(".arrived-select")?.value || "No";

        const payload = {
            productId: rowId,
            skuId: skuId,
            stock: stock,
            dateOfUpload: dateOfUpload,
            courierName: courierName,
            dateOfPickup: dateOfPickup,
            investedAmount: investedAmount,
            creditedAmount: creditedAmount,
            paymentStatus: paymentStatus,
            dateOfPayment: dateOfPayment,
            arrived: arrived
        };

        fetch('/ProductDetails/updateProductDetails', {
            method: 'POST',
            headers: {
                'Content-Type': 'application/json'
            },
            body: JSON.stringify(payload)
        })
        .then(res => res.json())
        .then(res => {
            if (res.statusCode === 200) {
                // Update profit label real-time
                const profit = creditedAmount - investedAmount;
                const profitCell = row.querySelector(".profit-amt");
                profitCell.textContent = "₹" + profit.toLocaleString('en-IN');
                if (profit >= 0) {
                    profitCell.className = "profit-amt text-success fw-bold";
                } else {
                    profitCell.className = "profit-amt text-danger fw-bold";
                }
            } else {
                console.error("Save row failed: ", res.message);
            }
        })
        .catch(err => console.error("Error saving row:", err));
    }

    function saveProduct() {
        const formElement = document.getElementById("addProductForm");
        const formData = new FormData(formElement);

        fetch('/ProductDetails/saveNewProduct', {
            method: 'POST',
            body: formData
        })
        .then(res => res.json())
        .then(res => {
            if (res.statusCode === 200) {
                // Hide modal and refresh list
                const modal = bootstrap.Modal.getInstance(document.getElementById('addProductModal'));
                modal.hide();
                formElement.reset();
                clearPhotoSelection();
                // Reset default date
                document.getElementById("dateOfUpload").value = new Date().toISOString().split('T')[0];
                loadProducts();
            } else {
                alert("Error saving product: " + res.message);
            }
        })
        .catch(err => {
            console.error("Error saving product:", err);
            alert("Error sending request to server.");
        });
    }

    function deleteProduct(productId) {
        if (!confirm("Are you sure you want to delete this product entry?")) return;

        fetch(`/ProductDetails/deleteProductItem?productId=${productId}`, {
            method: 'POST'
        })
        .then(res => res.json())
        .then(res => {
            if (res.statusCode === 200) {
                loadProducts();
            } else {
                alert("Failed to delete product: " + res.message);
            }
        })
        .catch(err => console.error("Error deleting product:", err));
    }

    function clearPhotoSelection() {
        const productPhotoInput = document.getElementById("productPhoto");
        const photoPreviewContainer = document.getElementById("photoPreviewContainer");
        const photoPreview = document.getElementById("photoPreview");

        if (productPhotoInput) productPhotoInput.value = "";
        if (photoPreview) photoPreview.src = "";
        if (photoPreviewContainer) photoPreviewContainer.classList.add("d-none");
    }
</script>
}

<style>
    /* Styling elements matching dark glassmorphism */
    .glass-modal {
        background: rgba(20, 20, 25, 0.9) !important;
        backdrop-filter: blur(20px);
        border: 1px solid rgba(255, 255, 255, 0.08);
        border-radius: 20px;
        box-shadow: 0 10px 40px rgba(0, 0, 0, 0.5);
    }

    .table input:focus, .table select:focus {
        background-color: rgba(255, 255, 255, 0.05) !important;
        border: 1px solid var(--accent-pink) !important;
        outline: none;
        box-shadow: 0 0 8px rgba(255, 71, 126, 0.4);
        border-radius: 4px;
    }
    
    .hover-zoom {
        transition: transform 0.3s ease;
    }
    
    .hover-zoom:hover {
        transform: scale(1.15);
    }
    
    .table-responsive {
        scrollbar-width: thin;
        scrollbar-color: var(--accent-pink) var(--bg-card);
    }

    .text-pink {
        color: var(--accent-pink);
    }
</style>
