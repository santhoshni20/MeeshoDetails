@{
    ViewData["Title"] = "Product Details & Ledger";
}

<div class="container-fluid my-4">
    <!-- Breadcrumb & Back -->
    <div class="d-flex justify-content-between align-items-center mb-4">
        <nav aria-label="breadcrumb">
            <ol class="breadcrumb mb-0">
                <li class="breadcrumb-item"><a asp-controller="Home" asp-action="Index" class="text-decoration-none text-muted">Home</a></li>
                <li class="breadcrumb-item active text-white" aria-current="page">Product Details Ledger</li>
            </ol>
        </nav>
        <a asp-controller="Home" asp-action="Index" class="btn-outline-premium btn-sm">
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" class="me-1"><line x1="19" y1="12" x2="5" y2="12"></line><polyline points="12 19 5 12 12 5"></polyline></svg>
            Back to Home
        </a>
    </div>

    <!-- Header Section -->
    <div class="mb-4">
        <h1 class="text-white fw-bold">Meesho Product Details & Financial Ledger</h1>
        <p class="text-muted">Track stock, shipment timelines, investments, credits, profits, and payment clearance status for your listings.</p>
    </div>

    <!-- Interactive Ledger Card -->
    <div class="glass-card p-4">
        <div class="d-flex justify-content-between align-items-center mb-3 flex-wrap gap-2">
            <h4 class="text-white fw-semibold mb-0">Product Catalog & Ledger Logs</h4>
            <button class="btn-premium btn-sm" onclick="addNewRow()">
                <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" class="me-1"><line x1="12" y1="5" x2="12" y2="19"></line><line x1="5" y1="12" x2="19" y2="12"></line></svg>
                Add New Entry
            </button>
        </div>

        <div class="table-responsive">
            <table class="table table-dark table-hover align-middle border-secondary" id="ledgerTable">
                <thead>
                    <tr class="border-bottom border-secondary text-uppercase fs-7 text-muted">
                        <th scope="col" style="width: 60px;">S.No</th>
                        <th scope="col">SKU ID</th>
                        <th scope="col" style="width: 100px;">Photo</th>
                        <th scope="col">Stock</th>
                        <th scope="col">Upload Date</th>
                        <th scope="col">Courier</th>
                        <th scope="col">Pickup Date</th>
                        <th scope="col">Invested (₹)</th>
                        <th scope="col">Credited (₹)</th>
                        <th scope="col">Profit (₹)</th>
                        <th scope="col" style="width: 160px;">Payment Status</th>
                        <th scope="col" class="conditional-col d-none">Payment Date</th>
                        <th scope="col" class="conditional-col d-none">Arrived</th>
                        <th scope="col" style="width: 80px;">Action</th>
                    </tr>
                </thead>
                <tbody id="ledgerTableBody">
                    <!-- Row 1 -->
                    <tr id="row_1" class="border-bottom border-secondary">
                        <td class="s-no text-white fw-semibold">1</td>
                        <td>
                            <input type="text" class="form-control form-control-sm bg-transparent border-0 text-white fw-medium w-100" value="MEESHO-SR-KATAN-01" />
                        </td>
                        <td>
                            <div class="position-relative overflow-hidden rounded border border-secondary" style="width: 60px; height: 60px;">
                                <img src="/images/product_saree.png" alt="Saree" class="w-100 h-100 object-fit-cover hover-zoom" />
                            </div>
                        </td>
                        <td>
                            <input type="number" class="form-control form-control-sm bg-transparent border-0 text-white w-75" value="15" />
                        </td>
                        <td>
                            <input type="date" class="form-control form-control-sm bg-transparent border-0 text-white" value="2026-06-15" />
                        </td>
                        <td>
                            <input type="text" class="form-control form-control-sm bg-transparent border-0 text-white" value="Delhivery" />
                        </td>
                        <td>
                            <input type="date" class="form-control form-control-sm bg-transparent border-0 text-white" value="2026-06-16" />
                        </td>
                        <td>
                            <input type="number" class="form-control form-control-sm bg-transparent border-0 text-white invested-amt" value="800" onchange="calculateProfit(1)" />
                        </td>
                        <td>
                            <input type="number" class="form-control form-control-sm bg-transparent border-0 text-white credited-amt" value="1899" onchange="calculateProfit(1)" />
                        </td>
                        <td class="profit-amt text-success fw-bold">₹1,099</td>
                        <td>
                            <select class="form-select form-select-sm bg-dark border-secondary text-white payment-status-select" onchange="onStatusChange(1)">
                                <option value="Unscheduled" selected>Unscheduled</option>
                                <option value="Pending">Pending</option>
                            </select>
                        </td>
                        <td class="conditional-col d-none">
                            <input type="date" class="form-control form-control-sm bg-dark border-secondary text-white" value="" />
                        </td>
                        <td class="conditional-col d-none">
                            <select class="form-select form-select-sm bg-dark border-secondary text-white">
                                <option value="No" selected>No</option>
                                <option value="Yes">Yes</option>
                            </select>
                        </td>
                        <td>
                            <button class="btn btn-sm btn-outline-danger border-0" onclick="deleteRow(1)">
                                🗑️
                            </button>
                        </td>
                    </tr>
                    <!-- Row 2 -->
                    <tr id="row_2" class="border-bottom border-secondary">
                        <td class="s-no text-white fw-semibold">2</td>
                        <td>
                            <input type="text" class="form-control form-control-sm bg-transparent border-0 text-white fw-medium w-100" value="MEESHO-SR-GEOR-02" />
                        </td>
                        <td>
                            <div class="position-relative overflow-hidden rounded border border-secondary" style="width: 60px; height: 60px;">
                                <img src="/images/product_saree.png" alt="Saree" class="w-100 h-100 object-fit-cover hover-zoom" />
                            </div>
                        </td>
                        <td>
                            <input type="number" class="form-control form-control-sm bg-transparent border-0 text-white w-75" value="8" />
                        </td>
                        <td>
                            <input type="date" class="form-control form-control-sm bg-transparent border-0 text-white" value="2026-06-18" />
                        </td>
                        <td>
                            <input type="text" class="form-control form-control-sm bg-transparent border-0 text-white" value="Shadowfax" />
                        </td>
                        <td>
                            <input type="date" class="form-control form-control-sm bg-transparent border-0 text-white" value="2026-06-19" />
                        </td>
                        <td>
                            <input type="number" class="form-control form-control-sm bg-transparent border-0 text-white invested-amt" value="950" onchange="calculateProfit(2)" />
                        </td>
                        <td>
                            <input type="number" class="form-control form-control-sm bg-transparent border-0 text-white credited-amt" value="1750" onchange="calculateProfit(2)" />
                        </td>
                        <td class="profit-amt text-success fw-bold">₹800</td>
                        <td>
                            <select class="form-select form-select-sm bg-dark border-secondary text-white payment-status-select" onchange="onStatusChange(2)">
                                <option value="Unscheduled">Unscheduled</option>
                                <option value="Pending" selected>Pending</option>
                            </select>
                        </td>
                        <td class="conditional-col d-none">
                            <input type="date" class="form-control form-control-sm bg-dark border-secondary text-white" value="2026-06-25" />
                        </td>
                        <td class="conditional-col d-none">
                            <select class="form-select form-select-sm bg-dark border-secondary text-white">
                                <option value="No">No</option>
                                <option value="Yes" selected>Yes</option>
                            </select>
                        </td>
                        <td>
                            <button class="btn btn-sm btn-outline-danger border-0" onclick="deleteRow(2)">
                                🗑️
                            </button>
                        </td>
                    </tr>
                    <!-- Row 3 -->
                    <tr id="row_3" class="border-bottom border-secondary">
                        <td class="s-no text-white fw-semibold">3</td>
                        <td>
                            <input type="text" class="form-control form-control-sm bg-transparent border-0 text-white fw-medium w-100" value="MEESHO-SR-BANAR-03" />
                        </td>
                        <td>
                            <div class="position-relative overflow-hidden rounded border border-secondary" style="width: 60px; height: 60px;">
                                <img src="/images/product_saree.png" alt="Saree" class="w-100 h-100 object-fit-cover hover-zoom" />
                            </div>
                        </td>
                        <td>
                            <input type="number" class="form-control form-control-sm bg-transparent border-0 text-white w-75" value="25" />
                        </td>
                        <td>
                            <input type="date" class="form-control form-control-sm bg-transparent border-0 text-white" value="2026-06-20" />
                        </td>
                        <td>
                            <input type="text" class="form-control form-control-sm bg-transparent border-0 text-white" value="Xpressbees" />
                        </td>
                        <td>
                            <input type="date" class="form-control form-control-sm bg-transparent border-0 text-white" value="2026-06-21" />
                        </td>
                        <td>
                            <input type="number" class="form-control form-control-sm bg-transparent border-0 text-white invested-amt" value="1200" onchange="calculateProfit(3)" />
                        </td>
                        <td>
                            <input type="number" class="form-control form-control-sm bg-transparent border-0 text-white credited-amt" value="2499" onchange="calculateProfit(3)" />
                        </td>
                        <td class="profit-amt text-success fw-bold">₹1,299</td>
                        <td>
                            <select class="form-select form-select-sm bg-dark border-secondary text-white payment-status-select" onchange="onStatusChange(3)">
                                <option value="Unscheduled" selected>Unscheduled</option>
                                <option value="Pending">Pending</option>
                            </select>
                        </td>
                        <td class="conditional-col d-none">
                            <input type="date" class="form-control form-control-sm bg-dark border-secondary text-white" value="" />
                        </td>
                        <td class="conditional-col d-none">
                            <select class="form-select form-select-sm bg-dark border-secondary text-white">
                                <option value="No" selected>No</option>
                                <option value="Yes">Yes</option>
                            </select>
                        </td>
                        <td>
                            <button class="btn btn-sm btn-outline-danger border-0" onclick="deleteRow(3)">
                                🗑️
                            </button>
                        </td>
                    </tr>
                </tbody>
            </table>
        </div>
    </div>
</div>

@section Scripts {
<script>
    document.addEventListener("DOMContentLoaded", function () {
        toggleConditionalColumns();
    });

    function toggleConditionalColumns() {
        const selectElements = document.querySelectorAll(".payment-status-select");
        let hasPending = false;

        selectElements.forEach(select => {
            if (select.value === "Pending") {
                hasPending = true;
            }
        });

        const conditionalCols = document.querySelectorAll(".conditional-col");
        conditionalCols.forEach(col => {
            if (hasPending) {
                col.classList.remove("d-none");
            } else {
                col.classList.add("d-none");
            }
        });
    }

    function onStatusChange(rowId) {
        toggleConditionalColumns();
        
        const row = document.getElementById("row_" + rowId);
        if (row) {
            const statusSelect = row.querySelector(".payment-status-select");
            const dateInput = row.querySelectorAll(".conditional-col")[0]?.querySelector("input");
            const arrivedSelect = row.querySelectorAll(".conditional-col")[1]?.querySelector("select");
            
            if (statusSelect.value !== "Pending") {
                if (dateInput) dateInput.value = "";
                if (arrivedSelect) arrivedSelect.value = "No";
            }
        }
    }

    function calculateProfit(rowId) {
        const row = document.getElementById("row_" + rowId);
        if (row) {
            const investedVal = parseFloat(row.querySelector(".invested-amt").value) || 0;
            const creditedVal = parseFloat(row.querySelector(".credited-amt").value) || 0;
            const profitCell = row.querySelector(".profit-amt");
            
            const profit = creditedVal - investedVal;
            
            profitCell.textContent = "₹" + profit.toLocaleString('en-IN');
            if (profit >= 0) {
                profitCell.className = "profit-amt text-success fw-bold";
            } else {
                profitCell.className = "profit-amt text-danger fw-bold";
            }
        }
    }

    let nextRowId = 4;
    function addNewRow() {
        const tbody = document.getElementById("ledgerTableBody");
        const rowId = nextRowId++;
        
        const tr = document.createElement("tr");
        tr.id = "row_" + rowId;
        tr.className = "border-bottom border-secondary";
        
        tr.innerHTML = `
            <td class="s-no text-white fw-semibold"></td>
            <td>
                <input type="text" class="form-control form-control-sm bg-transparent border-0 text-white fw-medium w-100" placeholder="SKU-CODE" />
            </td>
            <td>
                <div class="position-relative overflow-hidden rounded border border-secondary" style="width: 60px; height: 60px;">
                    <img src="/images/product_saree.png" alt="Saree" class="w-100 h-100 object-fit-cover hover-zoom" />
                </div>
            </td>
            <td>
                <input type="number" class="form-control form-control-sm bg-transparent border-0 text-white w-75" value="0" />
            </td>
            <td>
                <input type="date" class="form-control form-control-sm bg-transparent border-0 text-white" value="${new Date().toISOString().split('T')[0]}" />
            </td>
            <td>
                <input type="text" class="form-control form-control-sm bg-transparent border-0 text-white" placeholder="Courier Name" />
            </td>
            <td>
                <input type="date" class="form-control form-control-sm bg-transparent border-0 text-white" />
            </td>
            <td>
                <input type="number" class="form-control form-control-sm bg-transparent border-0 text-white invested-amt" value="0" onchange="calculateProfit(${rowId})" />
            </td>
            <td>
                <input type="number" class="form-control form-control-sm bg-transparent border-0 text-white credited-amt" value="0" onchange="calculateProfit(${rowId})" />
            </td>
            <td class="profit-amt text-success fw-bold">₹0</td>
            <td>
                <select class="form-select form-select-sm bg-dark border-secondary text-white payment-status-select" onchange="onStatusChange(${rowId})">
                    <option value="Unscheduled" selected>Unscheduled</option>
                    <option value="Pending">Pending</option>
                </select>
            </td>
            <td class="conditional-col d-none">
                <input type="date" class="form-control form-control-sm bg-dark border-secondary text-white" value="" />
            </td>
            <td class="conditional-col d-none">
                <select class="form-select form-select-sm bg-dark border-secondary text-white">
                    <option value="No" selected>No</option>
                    <option value="Yes">Yes</option>
                </select>
            </td>
            <td>
                <button class="btn btn-sm btn-outline-danger border-0" onclick="deleteRow(${rowId})">
                    🗑️
                </button>
            </td>
        `;
        
        tbody.appendChild(tr);
        updateSNo();
        toggleConditionalColumns();
    }

    function deleteRow(rowId) {
        const row = document.getElementById("row_" + rowId);
        if (row) {
            row.remove();
            updateSNo();
            toggleConditionalColumns();
        }
    }

    function updateSNo() {
        const sNoCells = document.querySelectorAll("#ledgerTableBody .s-no");
        sNoCells.forEach((cell, index) => {
            cell.textContent = index + 1;
        });
    }
</script>
}

<style>
    /* Table Input Focus States and Hover Zoom */
    .table input:focus, .table select:focus {
        background-color: rgba(255, 255, 255, 0.05) !important;
        border: 1px solid var(--accent-pink) !important;
        outline: none;
        box-shadow: 0 0 8px rgba(255, 71, 126, 0.4);
        border-radius: 4px;
    }
    
    .hover-zoom {
        transition: transform 0.3s ease;
    }
    
    .hover-zoom:hover {
        transform: scale(1.15);
    }
    
    .table-responsive {
        scrollbar-width: thin;
        scrollbar-color: var(--accent-pink) var(--bg-card);
    }
</style>
